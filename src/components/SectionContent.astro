---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<section class="mt-10">
  <div class="content-column pt-4">
    <h2 class="mb-3 text-xs font-medium uppercase tracking-[0.18em] text-gray-500">{title}</h2>
  </div>
  <div class="section-body content-column font-serif text-[1.1rem] leading-8 text-gray-800">
    <slot />
  </div>
</section>
