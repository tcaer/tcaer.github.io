---
import { Github, Linkedin, Mail } from 'lucide-astro';

const icons = {
  github: Github,
  linkedin: Linkedin,
  mail: Mail,
};

interface LinkItem {
  label: string;
  href: string;
  value: string;
  icon?: keyof typeof icons;
}

interface Props {
  title: string;
  description?: string;
  links?: LinkItem[];
}

const { title, description, links = [] } = Astro.props;
---

<header class="mx-auto w-full max-w-content">
  <h1 class="mb-8 max-w-[768px] font-body text-[32px] leading-[1.3] font-semibold tracking-normal text-text max-md:mb-6 max-md:text-[26px]">
    {title}
  </h1>
  {
    description && (
      <p class="mt-[1.35rem] max-w-[39rem] font-prose text-[18px] leading-[1.7] tracking-normal text-text-muted">
        {description}
      </p>
    )
  }
  {
    links.length > 0 && (
      <nav class="flex flex-col items-start gap-x-6 gap-y-3 min-[400px]:flex-row min-[400px]:flex-wrap" aria-label="Contact links">
        {links.map((link) => {
          const Icon = link.icon ? icons[link.icon] : undefined;

          return (
            <a
              class="inline-flex items-center gap-2 bg-[linear-gradient(var(--color-text-faint),var(--color-text-faint))] bg-[length:100%_1px] bg-left-bottom bg-no-repeat pb-0.5 font-body text-text-soft no-underline transition-colors duration-150 hover:bg-[linear-gradient(currentColor,currentColor)] hover:text-text"
              href={link.href}
              aria-label={link.label}
            >
              {Icon && <Icon class="size-4 shrink-0" strokeWidth={1.75} aria-hidden="true" />}
              <strong class="text-[16px] font-medium text-text">{link.value}</strong>
            </a>
          );
        })}
      </nav>
    )
  }
</header>
