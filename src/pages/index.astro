---
import Layout from '../layouts/Layout.astro';
import SectionContent from '../components/SectionContent.astro';

const roles = [
  {
    company: 'Sigma Computing',
    title: 'Senior Software Engineer',
    period: 'Aug 2023 - Present',
  },
  {
    company: 'Sutter Hill Ventures',
    title: 'Codepoint Fellow in Residence',
    period: 'Aug 2023 - Aug 2024',
  },
  {
    company: 'Microsoft',
    title: 'Software Engineer Intern',
    period: 'Summer 2022',
  },
  {
    company: 'Amazon',
    title: 'Software Development Engineer Intern',
    period: 'Summer 2021',
  },
];

const links = [
  { label: 'Email', href: 'mailto:tino.caer@me.com', value: 'tino.caer@me.com' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/tinocaer/', value: 'tinocaer' },
  { label: 'GitHub', href: 'https://github.com/tcaer', value: 'tcaer' },
];
---

<Layout
  title="Tino Caer"
  description="Tino Caer is a software engineer at Sigma Computing building interactive workflow systems and data platform features."
>
  <header class="content-column pt-10 pb-0 sm:pt-16">
    <h1 class="max-w-[12ch] text-5xl font-semibold tracking-[-0.04em] text-gray-800 sm:text-6xl">
      Tino Caer
    </h1>
    <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-600">
      {
        links.map((link) => (
          <a class="transition-colors hover:text-gray-800" href={link.href}>
            <span class="mr-2 text-gray-500">{link.label}</span>
            <span class="text-gray-700">{link.value}</span>
          </a>
        ))
      }
    </div>
  </header>

  <SectionContent title="About">
    <p>
      I&apos;m a Senior Software Engineer at Sigma Computing, where I build AI and workflow systems
      for Sigma workbooks. My recent work includes AI Builder, Sigma&apos;s AI copilot for
      workbooks, along with the core agent harness, evaluation infrastructure, and Actions.
    </p>
  </SectionContent>

  <SectionContent title="Experience">
    <div class="space-y-5">
      {
        roles.map((role) => (
          <article>
            <div class="grid gap-2 sm:grid-cols-[minmax(0,1fr)_10rem] sm:items-baseline sm:gap-6">
              <div class="min-w-0">
                <h3 class="text-2xl font-semibold tracking-[-0.025em] text-gray-800">
                  {role.company}
                </h3>
                <p class="font-serif mt-1 text-[1.05rem] italic text-gray-600">{role.title}</p>
              </div>
              <p class="text-sm text-gray-500 sm:justify-self-end">{role.period}</p>
            </div>
          </article>
        ))
      }
    </div>
  </SectionContent>
</Layout>
