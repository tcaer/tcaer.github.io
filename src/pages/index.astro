---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionContent from '../components/SectionContent.astro';
import { contactLinks, roles, site } from '../config/site';
---

<Layout
  title={site.title}
  description={site.description}
>
  <PageHeader title={site.name} links={contactLinks} />

  <SectionContent title="Experience">
    <div class="grid gap-0">
      {
        roles.map((role) => (
          <article class="mb-7 grid grid-cols-[minmax(0,1fr)_auto] items-baseline gap-gutter last:mb-0 max-md:mb-6 max-md:grid-cols-1 max-md:gap-[0.4rem]">
            <div>
              <h3 class="mb-1 font-body text-[21px] leading-[1.4] font-semibold tracking-normal text-text max-md:text-[20px]">
                {role.company}
              </h3>
              <time class="hidden font-body text-[16px] leading-[1.6] font-normal text-text-soft max-md:block">
                {role.period}
              </time>
              <p class="font-prose text-[18px] leading-[1.7] text-text-muted">{role.title}</p>
            </div>
            <time class="whitespace-nowrap font-body text-[16px] leading-[1.6] font-normal text-text-soft max-md:hidden">
              {role.period}
            </time>
          </article>
        ))
      }
    </div>
  </SectionContent>
</Layout>
